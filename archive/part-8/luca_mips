#!/bin/bash

set -euo pipefail

usage() {
	echo "Usage: luca_mips <input.quad> <output.s> [-O]" >&2
}

if [[ $# -lt 2 || $# -gt 3 ]]; then
	usage
	exit 1
fi

if [[ $# -eq 3 && $3 != "-O" ]]; then
	usage
	exit 1
fi

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
python3 "$script_dir/luca_mips.py" "$@"
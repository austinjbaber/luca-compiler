/* Compile with 'dot -Tpng graph.gv > graph.png' */

digraph problem3 { 
   standard [
      shape="record"; 
      label="{int | float}";
   ];

   // S_fields [
   //    shape="record";
   //    label="{int a | float b}"
   // ];

   sytab2 [
      shape="record";
      label="{struct S: fields = \{int a \| float b\}} | void foo(char)}";
   ];

   sytab1 [
      shape="record";
      label="{char x | struct S z}"
   ];

   sytab1 -> sytab2;
   sytab2 -> standard;
   // sytab2 -> S_fields;
}